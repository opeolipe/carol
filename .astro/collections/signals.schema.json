{
  "$ref": "#/definitions/signals",
  "definitions": {
    "signals": {
      "type": "object",
      "properties": {
        "observation": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "TRACKING",
            "DRIFTING",
            "STABILIZED"
          ],
          "default": "TRACKING"
        },
        "coordinates": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "observation",
        "category",
        "timestamp"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}