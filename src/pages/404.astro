---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found">
  <div class="py-24 text-center">
    <span class="text-[10px] uppercase tracking-widest text-zinc-400 font-bold mb-4 block">Error 404</span>
    <h1 class="text-4xl font-bold tracking-tight mb-6">Resource Missing or Restricted</h1>
    <p class="text-zinc-600 max-w-sm mx-auto mb-10 leading-relaxed">
      The page you are looking for might have been moved, deleted, or you may lack the necessary clearance.
    </p>
    <a href="/" class="text-sm font-bold uppercase tracking-tighter border border-zinc-900 px-6 py-3 hover:bg-zinc-900 hover:text-white transition-colors">
      Return to Dashboard
    </a>
  </div>
</BaseLayout>
