---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Product Manager & Cybersecurity Professional">
  <!-- Hero Section -->
  <section id="hero" class="h-screen w-full flex items-center justify-center relative overflow-hidden">
    <div class="text-center px-8">
      <h1 id="headline-1" class="text-4xl md:text-7xl font-bold tracking-tighter uppercase max-w-4xl">
        Products are built <br/> to be used.
      </h1>
      <h1 id="headline-2" class="text-4xl md:text-7xl font-bold tracking-tighter uppercase max-w-4xl absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 w-full px-8 pointer-events-none">
        I build them <br/> to be used safely.
      </h1>
    </div>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 text-[10px] uppercase tracking-[0.5em] font-bold animate-pulse">
      Scroll to explore
    </div>
  </section>

  <!-- Horizontal Scroll Section -->
  <section id="horizontal-section" class="relative group">
    <div class="sticky-container h-screen sticky top-0 overflow-hidden bg-zinc-950 text-white">
      <div id="horizontal-track" class="flex h-full items-center">
        <!-- Title Slide -->
        <div class="flex-shrink-0 w-screen h-full flex items-center justify-center px-12 md:px-24">
          <div class="max-w-2xl">
              <span class="text-[10px] uppercase tracking-[0.5em] text-zinc-500 mb-8 block">Selected Work</span>
              <h2 class="text-6xl md:text-9xl font-bold tracking-tighter uppercase mb-8">Proof <br/> of trust.</h2>
              <p class="text-zinc-400 text-lg md:text-xl max-w-sm">A gallery of systems designed with security at the core and privacy as a priority.</p>
          </div>
        </div>

        <!-- Project 1: KALEM -->
        <div class="flex-shrink-0 w-screen h-full flex items-center justify-center px-12 md:px-24">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center max-w-6xl w-full">
            <div class="relative aspect-video bg-zinc-900 border border-zinc-800 flex items-center justify-center overflow-hidden interactive group/card">
               <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:20px_20px] transition-transform duration-700 group-hover/card:scale-110"></div>
               <span class="text-[10px] font-mono text-zinc-500">Secure Sandbox Analysis V1.2</span>
            </div>
            <div>
              <span class="text-[10px] border border-zinc-700 px-3 py-1 uppercase tracking-widest text-zinc-500 mb-6 inline-block">Forensics</span>
              <h3 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-6">KALEM.</h3>
              <p class="text-zinc-400 text-lg mb-8">High-performance forensic engine for local analysis of digital fraud patterns in the Indonesian market.</p>
              <a href="https://github.com/carolinerat/kalem" class="interactive text-xs font-bold uppercase tracking-widest border-b border-white pb-2 hover:text-zinc-400 hover:border-zinc-400 transition-colors">Technical Repo</a>
            </div>
          </div>
        </div>

        <!-- Project 2: Spidtes -->
        <div class="flex-shrink-0 w-screen h-full flex items-center justify-center px-12 md:px-24">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center max-w-6xl w-full">
             <div class="relative aspect-video bg-zinc-900 border border-zinc-800 flex items-center justify-center overflow-hidden interactive group/card">
               <div class="absolute inset-0 opacity-20 [background-image:linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] [background-size:40px_40px] transition-transform duration-700 group-hover/card:scale-110"></div>
               <span class="text-[10px] font-mono text-zinc-500">Network Leak Detection</span>
            </div>
            <div>
              <span class="text-[10px] border border-zinc-700 px-3 py-1 uppercase tracking-widest text-zinc-500 mb-6 inline-block">Privacy</span>
              <h3 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-6">Spidtes.</h3>
              <p class="text-zinc-400 text-lg mb-8">Satirical tooling designed to expose invisible data leakage in consumer networks through education by exposure.</p>
              <a href="https://github.com/carolinerat/spidtes" class="interactive text-xs font-bold uppercase tracking-widest border-b border-white pb-2 hover:text-zinc-400 hover:border-zinc-400 transition-colors">Source Code</a>
            </div>
          </div>
        </div>

        <!-- Project 3: Mekari -->
        <div class="flex-shrink-0 w-screen h-full flex items-center justify-center px-12 md:px-24">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center max-w-6xl w-full">
             <div class="relative aspect-video bg-zinc-900 border border-zinc-800 flex items-center justify-center overflow-hidden interactive group/card">
               <div class="absolute inset-0 opacity-20 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white via-zinc-900 to-zinc-900 transition-transform duration-700 group-hover/card:scale-110"></div>
               <span class="text-[10px] font-mono text-zinc-500">Enterprise Adoption Logic</span>
            </div>
            <div>
              <span class="text-[10px] border border-zinc-700 px-3 py-1 uppercase tracking-widest text-zinc-500 mb-6 inline-block">SaaS</span>
              <h3 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-6">Mekari.</h3>
              <p class="text-zinc-400 text-lg mb-8">Leading product initiatives for HR and analytics workflows serving thousands of SMEs and enterprise users in Indonesia.</p>
              <a href={`${import.meta.env.BASE_URL}/about`} class="interactive text-xs font-bold uppercase tracking-widest border-b border-white pb-2 hover:text-zinc-400 hover:border-zinc-400 transition-colors">Narrative Profile</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final Section -->
  <section class="h-screen w-full flex items-center justify-center bg-white">
    <div class="text-center px-8 max-w-3xl">
      <span class="text-[10px] uppercase tracking-[0.5em] text-zinc-400 mb-8 block font-bold">Contact</span>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase mb-12">Building trust, one layer at a time.</h2>
      <div class="flex justify-between items-center border-t border-zinc-200 mt-12 py-8">
          <a href="mailto:carol@example.com" class="interactive text-xl font-bold tracking-tighter hover:text-zinc-500 transition-colors underline underline-offset-8 decoration-1">Email</a>
          <a href="https://linkedin.com/in/caroline-ratuolivia/" class="interactive text-xl font-bold tracking-tighter hover:text-zinc-500 transition-colors underline underline-offset-8 decoration-1">LinkedIn</a>
          <a href="https://github.com/opeolipe" class="interactive text-xl font-bold tracking-tighter hover:text-zinc-500 transition-colors underline underline-offset-8 decoration-1">GitHub</a>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Hero headline transition
    const heroTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      }
    });

    heroTl.to('#headline-1', {
      opacity: 0,
      y: -50,
      ease: 'power2.inOut'
    })
    .to('#headline-2', {
      opacity: 1,
      y: 0,
      ease: 'power2.inOut'
    }, '<');

    // Horizontal scroll logic
    const sections = gsap.utils.toArray('.flex-shrink-0');
    gsap.to('#horizontal-track', {
      xPercent: -100 * (sections.length - 1),
      ease: 'none',
      scrollTrigger: {
        trigger: '#horizontal-section',
        pin: true,
        scrub: 1,
        end: () => "+=" + (document.getElementById('horizontal-track')?.scrollWidth || 0),
        anticipatePin: 1,
      }
    });
  </script>
</BaseLayout>
