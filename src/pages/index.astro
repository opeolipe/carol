---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CinematicHero } from '../components/CinematicHero';
---

<BaseLayout title="Caroline Ratuolivia" minimal={true}>
  <CinematicHero client:load />

  {/* Next Section: Transitioning from noise into clarity */}
  <section id="essay-start" class="relative z-10 bg-[#fafafa] text-zinc-900 min-h-screen py-32 px-12 md:px-24">
    <div class="max-w-4xl mx-auto space-y-32">
      <div class="space-y-8">
        <span class="text-[10px] uppercase tracking-[0.4em] text-zinc-400 font-extrabold block mb-12">Chapter I: The Signal and the Noise</span>
        <h2 class="text-4xl md:text-6xl font-medium tracking-tight leading-tight text-zinc-900">
          We live in an age of architectural insecurity. 
          The tools we use to connect are the same ones used to observe.
        </h2>
        <p class="text-zinc-500 text-xl md:text-2xl font-light max-w-2xl leading-relaxed">
          The boundaries between utility and surveillance have blurred into a single, seamless surface. I spend my time examining the seams.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
        <div class="space-y-6">
          <h3 class="text-2xl font-bold tracking-tighter uppercase text-zinc-900">Systems & Strategy</h3>
          <p class="text-zinc-500 leading-relaxed font-light">
            My work sits at the intersection of product vision and digital integrity. I build systems that don't just solve problems, but respect the human on the other side of the screen.
          </p>
          <a href={`${import.meta.env.BASE_URL}/about`} class="interactive inline-block text-[10px] uppercase tracking-widest font-bold border-b border-zinc-200 pb-2 hover:border-black transition-colors">
            Read Profile
          </a>
        </div>
        <div class="aspect-[4/5] bg-zinc-100 overflow-hidden relative group border border-zinc-200/50">
           <div class="absolute inset-0 noise-texture opacity-30 group-hover:opacity-50 transition-opacity"></div>
           <div class="absolute inset-0 flex items-center justify-center">
             <span class="text-zinc-300 font-mono text-[10px]">DOCUMENT_01_REDACTED</span>
           </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-zinc-50 text-zinc-400 py-24 px-12 md:px-24 border-t border-zinc-200 mt-32">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12">
      <div class="space-y-4">
        <span class="text-xs font-bold uppercase tracking-widest text-zinc-900 block">Caroline Ratuolivia</span>
        <p class="text-sm font-light max-w-xs">Building thoughtful things for a noisy internet.</p>
      </div>
      <div class="flex gap-12">
        <div class="space-y-4">
          <span class="text-[10px] uppercase tracking-widest font-bold block text-zinc-900">Social</span>
          <div class="flex flex-col gap-2 text-sm">
            <a href="https://github.com/opeolipe" class="hover:text-zinc-900 transition-colors interactive">GitHub</a>
            <a href="https://linkedin.com/in/caroline-ratuolivia/" class="hover:text-zinc-900 transition-colors interactive">LinkedIn</a>
          </div>
        </div>
        <div class="space-y-4">
          <span class="text-[10px] uppercase tracking-widest font-bold block text-zinc-900">Legal</span>
          <div class="flex flex-col gap-2 text-sm">
            <a href={`${import.meta.env.BASE_URL}/privacy`} class="hover:text-zinc-900 transition-colors interactive">Privacy</a>
            <a href={`${import.meta.env.BASE_URL}/pgp.txt`} class="hover:text-zinc-900 transition-colors interactive">PGP</a>
          </div>
        </div>
      </div>
    </div>
    <div class="max-w-4xl mx-auto mt-24 pt-8 border-t border-zinc-200 flex justify-between items-center text-[10px] uppercase tracking-widest text-zinc-400 font-bold">
      <span>© 2026</span>
      <span>Secure by Design</span>
    </div>
  </footer>
</BaseLayout>

