---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CinematicHero } from '../components/CinematicHero';
---

<BaseLayout title="Caroline Ratuolivia" minimal={true}>
  <CinematicHero client:load />

  {/* Next Section: Transitioning from noise into clarity */}
  <section id="essay-start" class="relative z-10 bg-[#fbfbf9] text-zinc-900 min-h-screen py-48 px-12 md:px-24">
    <div class="max-w-4xl mx-auto space-y-48">
      <div class="space-y-12">
        <span class="text-[10px] uppercase tracking-[0.5em] text-zinc-300 font-extrabold block mb-16">Act II: The Signal and the Noise</span>
        <h2 class="text-5xl md:text-7xl font-medium tracking-tight leading-[0.95] text-zinc-900 max-w-3xl">
          We live in an age of architectural insecurity. 
          The tools we use to connect are the same ones used to observe.
        </h2>
        <p class="text-zinc-400 text-xl md:text-3xl font-light max-w-2xl leading-relaxed">
          The boundaries between utility and surveillance have blurred into a single, seamless surface. I spend my time examining the seams.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-32 items-start">
        <div class="space-y-10 pt-12">
          <div class="space-y-4">
             <h3 class="text-2xl font-bold tracking-tight uppercase text-zinc-900">Systems & Strategy</h3>
             <div class="w-8 h-px bg-zinc-200" />
          </div>
          <p class="text-zinc-500 text-lg leading-relaxed font-light max-w-sm">
            My work sits at the intersection of product vision and digital integrity. I build systems that don't just solve problems, but respect the human on the other side of the screen.
          </p>
          <a href={`${import.meta.env.BASE_URL}/about`} class="interactive inline-block text-[10px] uppercase tracking-[0.3em] font-bold border-b border-zinc-100 pb-2 hover:border-zinc-900 transition-all duration-500">
            Read Profile
          </a>
        </div>
        <div class="aspect-[3/4] bg-[#fdfdfc] overflow-hidden relative group border border-zinc-100/80 shadow-sm">
           <div class="absolute inset-0 noise-texture opacity-10 group-hover:opacity-30 transition-opacity duration-1000"></div>
           <div class="absolute inset-0 flex items-center justify-center p-12">
             <div class="w-full h-full border border-zinc-50 flex items-center justify-center">
                <span class="text-zinc-200 font-mono text-[9px] uppercase tracking-widest">fragment_01_obs</span>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-zinc-50 text-zinc-400 py-32 px-12 md:px-24 border-t border-zinc-100 mt-48">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-start gap-16">
      <div class="space-y-6">
        <span class="text-xs font-bold uppercase tracking-[0.4em] text-zinc-900 block">Caroline Ratuolivia</span>
        <p class="text-sm font-light max-w-xs leading-relaxed">Building thoughtful things for a noisy internet.</p>
      </div>
      <div class="flex gap-16">
        <div class="space-y-6">
          <span class="text-[10px] uppercase tracking-[0.4em] font-bold block text-zinc-900">Social</span>
          <div class="flex flex-col gap-3 text-sm">
            <a href="https://github.com/opeolipe" class="hover:text-zinc-900 transition-colors interactive">GitHub</a>
            <a href="https://linkedin.com/in/caroline-ratuolivia/" class="hover:text-zinc-900 transition-colors interactive">LinkedIn</a>
          </div>
        </div>
        <div class="space-y-6">
          <span class="text-[10px] uppercase tracking-[0.4em] font-bold block text-zinc-900">Legal</span>
          <div class="flex flex-col gap-3 text-sm">
            <a href={`${import.meta.env.BASE_URL}/privacy`} class="hover:text-zinc-900 transition-colors interactive">Privacy</a>
            <a href={`${import.meta.env.BASE_URL}/pgp.txt`} class="hover:text-zinc-900 transition-colors interactive">PGP</a>
          </div>
        </div>
      </div>
    </div>
    <div class="max-w-4xl mx-auto mt-32 pt-12 border-t border-zinc-100 flex justify-between items-center text-[10px] uppercase tracking-[0.4em] text-zinc-300 font-bold">
      <span>© 2026</span>
      <span>Secure by Design</span>
    </div>
  </footer>
</BaseLayout>

