---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

import { 
  InvestigationHeader, 
  InvestigationConclusion,
  ReadingEnvironment,
  ArchivePathway
} from '../../components/InvestigationReport';

const metadata = [
  { label: "Investigation_ID", value: entry.data.investigationId || "TRC-7429" },
  { label: "Signal_Category", value: entry.data.signalCategory || "Atmospheric" },
  { label: "Archive_State", value: entry.data.archiveState || "Stabilized" },
  { label: "Observation_Date", value: entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) },
];

// Fetch related traces
let relatedTracesData = [];
if (entry.data.relatedTraces && entry.data.relatedTraces.length > 0) {
  for (const slug of entry.data.relatedTraces) {
    const traceEntry = await getEntry('blog', slug);
    if (traceEntry) {
      relatedTracesData.push({
        title: traceEntry.data.title,
        slug: traceEntry.slug,
        investigationId: traceEntry.data.investigationId,
        category: traceEntry.data.signalCategory,
        description: traceEntry.data.description
      });
    }
  }
} else {
  // Fallback: pick any 2 from collection
  const allPosts = await getCollection('blog');
  relatedTracesData = allPosts
    .filter(p => p.slug !== entry.slug)
    .slice(0, 2)
    .map(p => ({
      title: p.data.title,
      slug: p.slug,
      investigationId: p.data.investigationId,
      category: p.data.signalCategory,
      description: p.data.description
    }));
}

// Fetch live monitoring signals
const rawSignals = await getCollection('signals');
const sortedSignals = rawSignals
  .sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime())
  .slice(0, 2)
  .map(s => ({
    observation: s.data.observation,
    category: s.data.category,
    timestamp: s.data.timestamp.toISOString(),
    status: s.data.status,
    coordinates: s.data.coordinates || ""
  }));

// Fetch brief unresolved field notes
const rawNotes = await getCollection('fieldNotes');
const sortedNotes = rawNotes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2)
  .map(n => ({
    title: n.data.title,
    slug: n.slug,
    category: n.data.category,
    observation: n.data.observation,
    insight: n.data.insight,
    unresolvedSignal: n.data.unresolvedSignal,
    pattern: n.data.pattern,
    date: n.data.date.toISOString(),
    coordinates: n.data.coordinates || ""
  }));
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <ReadingEnvironment client:load slug={entry.slug} state={entry.data.signalState}>
    <div class="max-w-7xl mx-auto px-8 md:px-24 pt-32 pb-[10vh]">
      <article class="relative z-10">
        <InvestigationHeader 
          title={entry.data.title}
          description={entry.data.description}
          metadata={metadata}
          state={entry.data.signalState}
          client:load
        />
        
        <div class="investigation-content">
          <Content />
        </div>

        <InvestigationConclusion client:load>
          The investigation remains open. The signals recorded suggest a deeper pattern of behavioral drift that requires further long-term observation. Traces will be updated as new data fragments emerge from the archive.
        </InvestigationConclusion>

        <ArchivePathway 
          client:load 
          traces={relatedTracesData} 
          signals={sortedSignals}
          fieldNotes={sortedNotes}
        />
      </article>
    </div>
  </ReadingEnvironment>
</BaseLayout>

<style is:global>
  /* Editorial Investigation Typography */
  .investigation-content {
    @apply mx-auto max-w-none;
  }
  .investigation-content p {
    @apply text-[1.1rem] md:text-[1.4rem] font-light text-zinc-600 leading-relaxed mb-8 md:mb-12 max-w-3xl;
  }
  .investigation-content h2 {
    @apply text-[2rem] md:text-[3rem] font-bold tracking-tighter uppercase mt-24 mb-8 text-zinc-950;
  }
  .investigation-content ul {
    @apply space-y-4 mb-12 border-l border-zinc-100 pl-8;
  }
  .investigation-content li {
    @apply text-[1rem] md:text-[1.2rem] font-mono uppercase tracking-widest text-zinc-400;
  }
</style>
